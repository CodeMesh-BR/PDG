APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_API_URL=/api/proxy

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Banco de dados (MySQL)
# Local (Docker): DB_HOST=db / porta 3306 (serviço "db" do docker-compose.yml)
# Servidor (cPanel): troque apenas estes valores pelos do MySQL do cPanel.
#   DB_HOST geralmente é "localhost" no cPanel; usuário/banco no formato cpaneluser_nome.
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=pdgdetailing_local
DB_USERNAME=pdg_local
DB_PASSWORD=pdg_local_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=
JWT_ISS="pdg_api"
JWT_AUD="pdg_users"
JWT_TTL=36000 # 10h em segundos
JWT_CLOCK_SKEW=60

GOOGLE_APPLICATION_CREDENTIALS=/var/www/html/storage/app/private/your-google-vision-credentials.json
GCV_LOCALE_HINT=en

CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_SUPPORTS_CREDENTIALS=false
CORS_MAX_AGE=86400
